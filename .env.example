# DocRunner configuration. Copy to .env and fill in.
# The container will NOT start without SECRET_KEY and ENCRYPTION_KEY.

# ── Required ────────────────────────────────────────────────
# Django secret key. Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Fernet key for encrypting stored Secrets. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# BACK THIS UP — losing it makes all stored secrets unrecoverable.
ENCRYPTION_KEY=

# ── Core ────────────────────────────────────────────────────
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=UTC
LOG_LEVEL=INFO

# ── Workers ─────────────────────────────────────────────────
Q_WORKERS=2          # background task workers (generation + delivery)
WEB_WORKERS=3        # gunicorn web workers

# ── Email / SMTP (used for magic-link login AND document delivery) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=docrunner@localhost
# The SMTP password is stored as an encrypted Secret named SMTP_PASSWORD,
# not here. This var only names which Secret to read.
SMTP_PASSWORD_SECRET=SMTP_PASSWORD

# ── Advanced ────────────────────────────────────────────────
# DATA_DIR=/app/data       # where SQLite, templates, and outputs live
# SOFFICE_BIN=soffice      # path to LibreOffice binary
# SECURE_SSL_REDIRECT=True  # force HTTPS in production
